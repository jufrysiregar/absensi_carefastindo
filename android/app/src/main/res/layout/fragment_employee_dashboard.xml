<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Employee Info & Realtime Clock Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toStartOf="@id/layoutClock"
                            android:layout_alignParentStart="true"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:id="@+id/txtEmployeeName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Karyawan Carefastindo"
                                android:textColor="@color/primary"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtEmployeeRole"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pegawai - Shift Pagi"
                                android:textColor="@color/text_secondary_light"
                                android:textSize="14sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutClock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end"
                            android:layout_alignParentEnd="true">

                            <TextView
                                android:id="@+id/txtLiveTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00:00:00"
                                android:textColor="@color/text_primary_light"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtLiveDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Selasa, 19 Mei 2026"
                                android:textColor="@color/text_secondary_light"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Lateness Peringatan Telat Card (Initially GONE) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/latenessWarningCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/error"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        android:tint="@color/white" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PERINGATAN KETELAMBATAN!"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Anda telah 3 kali terlambat. Harap lebih disiplin. Admin akan melihat laporan ini."
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Admin Custom Notification Card (Initially GONE) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/adminNotificationCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/accent"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_dialog_info"
                        android:tint="@color/white" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PENGUMUMAN ADMIN"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtAdminNotificationContent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pemberitahuan khusus dari admin."
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Today's Attendance Status Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STATUS ABSENSI HARI INI"
                        android:textColor="@color/text_primary_light"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/txtTodayStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status hari ini: Belum absen masuk"
                        android:textColor="@color/text_primary_light"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:weightSum="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Masuk"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary_light" />

                            <TextView
                                android:id="@+id/txtCheckInTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Istirahat"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary_light" />

                            <TextView
                                android:id="@+id/txtBreakTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/accent"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pulang"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary_light" />

                            <TextView
                                android:id="@+id/txtCheckOutTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Actions Panel -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="TINDAKAN PRESENSI"
                            android:textColor="@color/text_primary_light"
                            android:textStyle="bold"
                            android:textSize="13sp" />

                        <ImageView
                            android:id="@+id/btnInfoJadwal"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="#000000"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true" />
                    </RelativeLayout>

                    <!-- Absen Masuk Button (Green) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCheckIn"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="ABSEN MASUK"
                        android:textColor="@color/white"
                        android:backgroundTint="#10B981"
                        app:icon="@android:drawable/ic_menu_myplaces"
                        app:cornerRadius="12dp"
                        android:layout_marginBottom="12dp"
                        android:textStyle="bold" />

                    <!-- Istirahat Button (Orange) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBreak"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="ISTIRAHAT"
                        android:textColor="@color/white"
                        android:backgroundTint="#F59E0B"
                        app:icon="@android:drawable/ic_menu_today"
                        app:cornerRadius="12dp"
                        android:layout_marginBottom="12dp"
                        android:textStyle="bold" />

                    <!-- Absen Pulang Button (Blue) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCheckOut"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="ABSEN PULANG"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/primary"
                        app:icon="@android:drawable/ic_lock_power_off"
                        app:cornerRadius="12dp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
