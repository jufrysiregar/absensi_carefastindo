<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtDateFull"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="05/07/2026"
            android:textColor="@color/text_primary_light"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtScheduleValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Jadwal Kamu : Shift Pagi (07:00 s/d 15:00)"
            android:textColor="@color/text_primary_light"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtStatusValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Status : Belum Absen"
            android:textColor="@color/text_primary_light"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtChangeValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Perubahan Jadwal : -"
            android:textColor="@color/text_secondary_light"
            android:textSize="13sp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>