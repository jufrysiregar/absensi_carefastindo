<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Top Action Panel -->
    <LinearLayout
        android:id="@+id/actionPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnSelectMonth"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_weight="1.2"
            android:layout_height="wrap_content"
            android:text="Pilih Bulan &amp; Tahun"
            app:icon="@android:drawable/ic_menu_my_calendar"
            android:textColor="@color/primary"
            app:strokeColor="@color/primary" />

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnGenerateAll"
            style="@style/Widget.Material3.Button.ElevatedButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Generate Semua"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:visibility="gone" />
    </LinearLayout>

    <!-- RecyclerView listing Employee stats and editable payroll fields -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewSalary"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/actionPanel"
        android:padding="12dp"
        android:clipToPadding="false" />

    <TextView
        android:id="@+id/txtNoData"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Pilih Bulan &amp; Tahun terlebih dahulu untuk memuat data rekap"
        android:textColor="@color/text_secondary_light"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="20dp" />

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80FFFFFF"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/primary" />
    </FrameLayout>
</RelativeLayout>
