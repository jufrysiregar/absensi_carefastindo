<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <!-- Profile Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_horizontal">

                    <!-- Default Avatar Icon -->
                    <ImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:src="@android:drawable/sym_def_app_icon"
                        android:tint="@color/primary"
                        android:scaleType="fitCenter"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/txtName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="M. Juffri Siregar"
                        android:textColor="@color/text_primary_light"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="jufry@carefastindo.com"
                        android:textColor="@color/text_secondary_light"
                        android:textSize="14sp"
                        android:layout_marginTop="2dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E8F0"
                        android:layout_marginVertical="16dp" />

                    <!-- Detailed Info Fields -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Employee Code -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kode Pegawai"
                                android:textColor="@color/text_secondary_light"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/txtEmployeeCode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="CF0001"
                                android:textColor="@color/text_primary_light"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Role -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Level / Peran"
                                android:textColor="@color/text_secondary_light"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/txtRole"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Pegawai"
                                android:textColor="@color/text_primary_light"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Shift -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Shift Kerja"
                                android:textColor="@color/text_secondary_light"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/txtShift"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Pagi"
                                android:textColor="@color/text_primary_light"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Position -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Posisi / Jabatan"
                                android:textColor="@color/text_secondary_light"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/txtPosition"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Staff Operational"
                                android:textColor="@color/text_primary_light"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Lateness Count -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Keterlambatan Bulan Ini"
                                android:textColor="@color/text_secondary_light"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/txtLatenessCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="0 Kali"
                                android:textColor="@color/error"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Face Registration Status -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Status Wajah"
                                android:textColor="@color/text_secondary_light"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/txtFaceStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Memuat..."
                                android:textColor="@color/text_primary_light"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Actions Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Register Face Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegisterFace"
                        style="@style/Widget.Material3.Button.ElevatedButton"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Registrasi Wajah"
                        android:textColor="@color/primary"
                        app:icon="@android:drawable/ic_menu_camera"
                        app:cornerRadius="10dp"
                        android:layout_marginBottom="12dp"
                        android:textStyle="bold" />

                    <!-- Change Password Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChangePassword"
                        style="@style/Widget.Material3.Button.ElevatedButton"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Ganti Kata Sandi"
                        android:textColor="@color/primary"
                        app:icon="@android:drawable/ic_lock_idle_lock"
                        app:cornerRadius="10dp"
                        android:layout_marginBottom="12dp"
                        android:textStyle="bold" />

                    <!-- Logout Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogout"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="KEDALAM KELUAR (LOGOUT)"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/error"
                        app:icon="@android:drawable/ic_lock_power_off"
                        app:cornerRadius="10dp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Overlay Loader -->
    <RelativeLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:indeterminateTint="@color/white" />
    </RelativeLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
