<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Premium Developer Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_light"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- Profile Photo Container -->
                <androidx.cardview.widget.CardView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="4dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/white">

                    <ImageView
                        android:id="@+id/imgDeveloperPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/foto_developer"
                        android:scaleType="centerCrop"
                        android:contentDescription="Foto Developer" />
                </androidx.cardview.widget.CardView>

                <!-- App Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERANCANGAN APLIKASI ABSENSI PEGAWAI MENGGUNAKAN METODE QR CODE BERBASIS ANDROID PADA PT. CAREFASTINDO"
                    android:textColor="@color/text_primary_light"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <!-- Version Badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="V1.0.0 (Build Release)"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold|italic"
                    android:gravity="center" />

                <!-- Thesis Disclaimer / Description -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Aplikasi ini dikembangkan sebagai tugas akhir (Skripsi) untuk memenuhi syarat kelulusan jenjang Strata-1 (S1) pada Universitas Potensi Utama."
                    android:textColor="@color/text_secondary_light"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.2"
                    android:gravity="center" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Detailed Data Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_light"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Section: Data Developer -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data Developer"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB"
                    android:layout_marginBottom="16dp" />

                <!-- Key Value Rows -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Nama Lengkap -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Nama Lengkap"
                            android:textColor="@color/text_secondary_light"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/text_secondary_light"
                            android:layout_marginEnd="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="M. Juffri Siregar"
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- NIM -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="NIM"
                            android:textColor="@color/text_secondary_light"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/text_secondary_light"
                            android:layout_marginEnd="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1912000103"
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Fakultas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Fakultas"
                            android:textColor="@color/text_secondary_light"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/text_secondary_light"
                            android:layout_marginEnd="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fakultas Teknik dan Ilmu Komputer"
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Program Studi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Program Studi"
                            android:textColor="@color/text_secondary_light"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/text_secondary_light"
                            android:layout_marginEnd="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Informatika"
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Universitas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Universitas"
                            android:textColor="@color/text_secondary_light"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/text_secondary_light"
                            android:layout_marginEnd="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Universitas Potensi Utama"
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Gelar Penghargaan -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Gelar"
                            android:textColor="@color/text_secondary_light"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/text_secondary_light"
                            android:layout_marginEnd="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sarjana Komputer (S. Kom)"
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Section: Dosen Pembimbing -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dosen Pembimbing &amp; Penguji"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Dosen Pembimbing -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Dosen Pembimbing"
                            android:textColor="@color/text_secondary_light"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/text_secondary_light"
                            android:layout_marginEnd="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fitriana Harahap, M. Kom"
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Dosen Penguji I -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Dosen Penguji I"
                            android:textColor="@color/text_secondary_light"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/text_secondary_light"
                            android:layout_marginEnd="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Budi Triandi, M. Kom"
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Dosen Penguji II -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Dosen Penguji II"
                            android:textColor="@color/text_secondary_light"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/text_secondary_light"
                            android:layout_marginEnd="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ratna Sari Hayati, M. Kom"
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Section: Timeline Pengembangan Aplikasi -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Timeline Pengembangan Aplikasi:"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Item 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RelativeLayout
                            android:layout_width="24dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="12dp">
                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:layout_centerHorizontal="true"
                                android:background="#3B82F6" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="●"
                                android:textColor="#000000"
                                android:textSize="12sp"
                                android:layout_centerHorizontal="true"
                                android:layout_marginTop="2dp"
                                android:background="@color/surface_light" />
                        </RelativeLayout>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="22 Nov 2022 – 13 Feb 2023: Acc Judul &amp; Acc Proposal Skripsi."
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp"
                            android:layout_marginBottom="16dp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>

                    <!-- Item 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RelativeLayout
                            android:layout_width="24dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="12dp">
                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:layout_centerHorizontal="true"
                                android:background="#3B82F6" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="●"
                                android:textColor="#000000"
                                android:textSize="12sp"
                                android:layout_centerHorizontal="true"
                                android:layout_marginTop="2dp"
                                android:background="@color/surface_light" />
                        </RelativeLayout>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="01 Agu 2023: Revisi judul dan implementasi fitur keamanan aplikasi."
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp"
                            android:layout_marginBottom="16dp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>

                    <!-- Item 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RelativeLayout
                            android:layout_width="24dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="12dp">
                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:layout_centerHorizontal="true"
                                android:background="#3B82F6" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="●"
                                android:textColor="#000000"
                                android:textSize="12sp"
                                android:layout_centerHorizontal="true"
                                android:layout_marginTop="2dp"
                                android:background="@color/surface_light" />
                        </RelativeLayout>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="07 Sep 2023: Demo / Pemaparan aplikasi."
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp"
                            android:layout_marginBottom="16dp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>

                    <!-- Item 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RelativeLayout
                            android:layout_width="24dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="12dp">
                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:layout_centerHorizontal="true"
                                android:background="#3B82F6" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="●"
                                android:textColor="#000000"
                                android:textSize="12sp"
                                android:layout_centerHorizontal="true"
                                android:layout_marginTop="2dp"
                                android:background="@color/surface_light" />
                        </RelativeLayout>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="11 Des 2023: Presentasi aplikasi dan Sidang Skripsi."
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp"
                            android:layout_marginBottom="16dp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>

                    <!-- Item 5 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RelativeLayout
                            android:layout_width="24dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="12dp">
                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:layout_centerHorizontal="true"
                                android:background="#3B82F6" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="●"
                                android:textColor="#000000"
                                android:textSize="12sp"
                                android:layout_centerHorizontal="true"
                                android:layout_marginTop="2dp"
                                android:background="@color/surface_light" />
                        </RelativeLayout>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="18 Mei 2026 – 21 Mei 2026: Finalisasi / Penyempurnaan sistem [Selesai]."
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Copyright footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:text="© 2023 M. Juffri Siregar | Absensi Pegawai PT. Carefastindo Indonesia. All Rights Reserved."
            android:textColor="@color/text_secondary_light"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
