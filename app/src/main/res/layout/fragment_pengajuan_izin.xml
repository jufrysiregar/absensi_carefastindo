<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Leave Request Input Form Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FORMULIR PENGAJUAN"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp" />

                    <!-- RadioGroup for Type (Izin / Sakit) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jenis Pengajuan"
                        android:textColor="@color/text_primary_light"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <RadioGroup
                        android:id="@+id/rgLeaveType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp"
                        android:checkedButton="@id/rbIzin">

                        <RadioButton
                            android:id="@+id/rbIzin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Izin"
                            android:textColor="@color/text_primary_light"
                            android:buttonTint="@color/primary"
                            android:layout_marginEnd="24dp" />

                        <RadioButton
                            android:id="@+id/rbSakit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sakit"
                            android:textColor="@color/text_primary_light"
                            android:buttonTint="@color/primary" />
                    </RadioGroup>

                    <!-- Date Selection Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="16dp">

                        <!-- Start Date -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tanggal Mulai"
                                android:textColor="@color/text_primary_light"
                                android:textSize="13sp"
                                android:layout_marginBottom="6dp" />

                            <androidx.cardview.widget.CardView
                                android:id="@+id/btnStartDate"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#F1F5F9">

                                <RelativeLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:paddingHorizontal="12dp">

                                    <TextView
                                        android:id="@+id/txtStartDate"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_centerVertical="true"
                                        android:text="Pilih Tanggal"
                                        android:textColor="@color/text_primary_light"
                                        android:textSize="14sp" />

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_alignParentEnd="true"
                                        android:layout_centerVertical="true"
                                        android:src="@android:drawable/ic_menu_my_calendar"
                                        android:tint="@color/text_secondary_light" />
                                </RelativeLayout>
                            </androidx.cardview.widget.CardView>
                        </LinearLayout>

                        <!-- End Date -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tanggal Selesai"
                                android:textColor="@color/text_primary_light"
                                android:textSize="13sp"
                                android:layout_marginBottom="6dp" />

                            <androidx.cardview.widget.CardView
                                android:id="@+id/btnEndDate"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#F1F5F9">

                                <RelativeLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:paddingHorizontal="12dp">

                                    <TextView
                                        android:id="@+id/txtEndDate"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_centerVertical="true"
                                        android:text="Pilih Tanggal"
                                        android:textColor="@color/text_primary_light"
                                        android:textSize="14sp" />

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_alignParentEnd="true"
                                        android:layout_centerVertical="true"
                                        android:src="@android:drawable/ic_menu_my_calendar"
                                        android:tint="@color/text_secondary_light" />
                                </RelativeLayout>
                            </androidx.cardview.widget.CardView>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Reason multiline input -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Alasan Pengajuan"
                        android:layout_marginBottom="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etReason"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:gravity="top|start"
                            android:inputType="textMultiLine"
                            android:textColor="@color/text_primary_light"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Proof Upload Section (Only visible for Sakit) -->
                    <LinearLayout
                        android:id="@+id/layoutAttachment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Unggah Bukti Surat Sakit"
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnChooseAttachment"
                            style="@style/Widget.Material3.Button.ElevatedButton"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Pilih Gambar dari Kamera/Galeri"
                            android:textColor="@color/primary"
                            app:icon="@android:drawable/ic_menu_camera"
                            app:cornerRadius="8dp" />

                        <ImageView
                            android:id="@+id/imgAttachmentPreview"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="8dp"
                            android:scaleType="centerCrop"
                            android:visibility="gone"
                            android:contentDescription="Preview Bukti Sakit"
                            android:background="#E2E8F0" />
                    </LinearLayout>

                    <!-- Submit Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="KIRIM PENGAJUAN"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="10dp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- History Section Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RIWAYAT PENGAJUAN"
                android:textColor="@color/text_primary_light"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <!-- Empty State View -->
            <TextView
                android:id="@+id/txtEmptyHistory"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:gravity="center"
                android:text="Belum ada data saat ini"
                android:textColor="@color/text_secondary_light"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- History List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLeaveHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_leave_request_employee" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Overlay Loader -->
    <RelativeLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:indeterminateTint="@color/white" />
    </RelativeLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
